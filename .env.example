# 飞书自建应用配置（交互式卡片）
# 获取方法：
# 1. 登录 https://open.feishu.cn 创建企业自建应用
# 2. 获取 App ID 和 App Secret
# 3. 开启机器人能力，在事件订阅中选择长连接模式
# 4. 添加 card.action.trigger 回调事件
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 飞书群组 Chat ID（可选，留空则自动获取机器人所在的第一个群）
# FEISHU_CHAT_ID=

# 默认宿主（claude 或 codex）
DEFAULT_AGENT_HOST=claude

# Codex CLI 可执行名（默认 codex）
# CODEX_BIN=codex

# 通知配置
# 是否启用飞书通知 (true/false)
NOTIFICATION_ENABLED=true

# 卡片交互有效期（小时，默认 12）
# NOTIFICATION_EXPIRE_HOURS=12
# 卡片交互有效期（分钟，优先于小时配置；可选）
# FEISHU_CARD_EXPIRE_MINUTES=30

# 卡片显示 Esc 按钮（默认关闭）
# ENABLE_ESC_BUTTON=true

# 是否启用声音提醒 (true/false)
SOUND_ENABLED=true

# tmux 会话目标（可选，仅 tmux 用户需要）
# 格式: session_name:window_index.pane_index (例如 claude:0.0)
# 留空则自动检测终端
# CLAUDE_TMUX_TARGET=

# 实时执行通知（PostToolUse hook，需在 settings.json 中配置 live-handler.js）
# 开启后 Bash/Write/Edit 执行情况实时推送到飞书，整个会话共用一张卡片（原地累积更新）
# 支持值：1/true（全部捕获）或 tools,output,results（精细控制各项内容）
# FEISHU_LIVE_CAPTURE=1
# Debounce 聚合延迟（毫秒，默认 3000，3 秒内无新工具调用则发送）
# FEISHU_LIVE_DEBOUNCE_MS=3000
